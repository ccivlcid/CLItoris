{
  "$comment": "Single source of truth for all design token values. DESIGN_GUIDE.md references this file.",
  "colors": {
    "background": {
      "primary": "#0d1117",
      "secondary": "#16213e",
      "surface": "#161b22",
      "hover": "#1e293b",
      "input": "#0d1117",
      "selection": "#264f78",
      "cli": "#0d1117"
    },
    "text": {
      "primary": "#e6edf3",
      "secondary": "#94a3b8",
      "muted": "#7d8590",
      "disabled": "#6b7280",
      "inverse": "#0f172a"
    },
    "accent": {
      "green": "#3fb950",
      "red": "#f85149",
      "yellow": "#d29922",
      "blue": "#58a6ff",
      "purple": "#bc8cff",
      "cyan": "#76e3ea",
      "orange": "#f0883e",
      "pink": "#f778ba",
      "emerald": "#34d399",
      "amber": "#fbbf24",
      "sky": "#38bdf8"
    },
    "semantic": {
      "cliKeyword": "#3fb950",
      "cliString": "#d29922",
      "cliFlag": "#58a6ff",
      "username": "#d29922",
      "hashtag": "#76e3ea",
      "mention": "#58a6ff",
      "langTag": "#bc8cff",
      "prompt": "#3fb950",
      "error": "#f85149",
      "warning": "#d29922",
      "success": "#34d399",
      "star": "#d29922",
      "cursor": "#58a6ff",
      "hint": "rgba(209, 153, 34, 0.7)"
    },
    "border": {
      "default": "#30363d",
      "hover": "#475569",
      "active": "#3fb950",
      "focus": "rgba(63, 185, 80, 1)",
      "success": "rgba(52, 211, 153, 1)",
      "warning": "rgba(209, 153, 34, 1)",
      "error": "rgba(248, 81, 73, 0.3)"
    },
    "chart": {
      "green": "#3fb950",
      "amber": "#fbbf24",
      "red": "#f85149",
      "dim": "#1e293b",
      "bg": "#0d1117"
    },
    "fx": {
      "scanline": "rgba(0, 0, 0, 0.1)",
      "glow": "rgba(74, 222, 128, 0.4)",
      "noise": "rgba(255, 255, 255, 0.02)"
    }
  },
  "typography": {
    "fontFamily": {
      "mono": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'Consolas', monospace",
      "sans": "'Inter', 'Segoe UI', 'Roboto', 'Helvetica', 'Arial', sans-serif"
    },
    "fontSize": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "code": "13px"
    },
    "lineHeight": {
      "normal": "1.6",
      "code": "1.5",
      "compact": "1.2"
    }
  },
  "spacing": {
    "postCard": { "padding": "1rem", "gap": "0.75rem" },
    "sidebar": { "width": "14rem", "padding": "1rem" },
    "composer": { "padding": "1rem", "gap": "0.5rem" },
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px"
  },
  "breakpoints": {
    "mobile": "640px",
    "tablet": "1024px",
    "desktop": "1280px"
  },
  "animation": {
    "blink": "opacity 1s step-end infinite",
    "fadeIn": "opacity 0.15s ease-in",
    "slideUp": "translateY 0.2s ease-out",
    "streamingLog": "0.4s",
    "flicker": "0.15s ease-in-out"
  },
  "effects": {
    "scanlineOpacity": 0.05,
    "glowSpread": "4px",
    "noiseOpacity": 0.02,
    "flickerOpacity": 0.95
  },
  "z-index": {
    "base": 0,
    "dropdown": 10,
    "sticky": 20,
    "sidebar": 30,
    "modal": 40,
    "toast": 50
  }
}
