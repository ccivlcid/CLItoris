{
  "$comment": "Single source of truth for all design token values. DESIGN_GUIDE.md references this file.",
  "colors": {
    "background": {
      "primary": "#0d1117",
      "surface": "#161b22",
      "hover": "#1e293b",
      "input": "#0d1117",
      "selection": "#264f78"
    },
    "text": {
      "primary": "#e6edf3",
      "secondary": "#94a3b8",
      "muted": "#7d8590",
      "disabled": "#6b7280",
      "inverse": "#0f172a"
    },
    "accent": {
      "green": "#3fb950",
      "red": "#f85149",
      "yellow": "#d29922",
      "blue": "#58a6ff",
      "purple": "#bc8cff",
      "cyan": "#76e3ea",
      "orange": "#f0883e",
      "pink": "#f778ba",
      "emerald": "#34d399"
    },
    "semantic": {
      "cliKeyword": "#3fb950",
      "cliString": "#d29922",
      "cliFlag": "#58a6ff",
      "username": "#d29922",
      "hashtag": "#76e3ea",
      "mention": "#58a6ff",
      "langTag": "#bc8cff",
      "prompt": "#3fb950",
      "error": "#f85149",
      "warning": "#d29922",
      "success": "#34d399",
      "star": "#d29922",
      "cursor": "#58a6ff",
      "hint": "rgba(209, 153, 34, 0.7)"
    },
    "border": {
      "default": "#30363d",
      "hover": "#475569",
      "active": "#3fb950",
      "focus": "rgba(63, 185, 80, 1)",
      "success": "rgba(52, 211, 153, 1)",
      "warning": "rgba(209, 153, 34, 1)",
      "error": "rgba(248, 81, 73, 0.3)"
    }
  },
  "tailwindMapping": {
    "$comment": "Maps design tokens to Tailwind CSS utility classes (terminal-* prefix in tailwind.config.ts)",
    "background.primary": "bg-terminal-bg",
    "background.surface": "bg-terminal-surface",
    "background.selection": "bg-terminal-selection",
    "text.primary": "text-terminal-text",
    "text.muted": "text-terminal-muted",
    "accent.green": "text-terminal-green",
    "accent.red": "text-terminal-red",
    "accent.yellow": "text-terminal-yellow",
    "accent.blue": "text-terminal-blue",
    "accent.purple": "text-terminal-purple",
    "accent.cyan": "text-terminal-cyan",
    "accent.orange": "text-terminal-orange",
    "accent.pink": "text-terminal-pink",
    "semantic.prompt": "text-terminal-prompt",
    "semantic.cursor": "text-terminal-cursor",
    "border.default": "border-terminal-border"
  },
  "typography": {
    "fontFamily": {
      "mono": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'Consolas', monospace",
      "sans": "'Inter', 'Segoe UI', 'Roboto', 'Helvetica', 'Arial', sans-serif"
    },
    "fontSize": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem"
    }
  },
  "spacing": {
    "postCard": { "padding": "1rem", "gap": "0.75rem" },
    "sidebar": { "width": "14rem", "padding": "1rem" },
    "composer": { "padding": "1rem", "gap": "0.5rem" }
  },
  "breakpoints": {
    "mobile": "640px",
    "tablet": "1024px",
    "desktop": "1280px"
  },
  "animation": {
    "blink": "opacity 1s step-end infinite",
    "fadeIn": "opacity 0.15s ease-in",
    "slideUp": "translateY 0.2s ease-out"
  },
  "shadows": {
    "card": "0 1px 3px rgba(0, 0, 0, 0.3)",
    "dropdown": "0 4px 12px rgba(0, 0, 0, 0.5)"
  }
}
